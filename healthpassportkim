<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>건강여권 — 김OO</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&family=Noto+Sans+KR:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1a2744;
    --navy-mid: #243258;
    --navy-light: #2e3f6e;
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --gold-pale: #f5ead4;
    --red-alert: #c0392b;
    --red-soft: #fdf0ee;
    --red-border: #e8b4ae;
    --yellow-alert: #b8860b;
    --yellow-soft: #fefbf0;
    --yellow-border: #e8d98a;
    --green-alert: #2d6a4f;
    --green-soft: #f0faf5;
    --green-border: #a8d5b5;
    --gray-100: #f8f9fa;
    --gray-200: #e9ecef;
    --gray-400: #868e96;
    --gray-600: #495057;
    --gray-800: #212529;
    --white: #ffffff;
    --shadow-sm: 0 2px 8px rgba(26,39,68,0.08);
    --shadow-md: 0 4px 20px rgba(26,39,68,0.12);
    --shadow-lg: 0 8px 40px rgba(26,39,68,0.18);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: #eef1f8;
    color: var(--gray-800);
    min-height: 100vh;
    padding: 32px 16px 60px;
  }

  .passport-wrapper {
    max-width: 780px;
    margin: 0 auto;
  }

  /* ── 표지 ── */
  .passport-cover {
    background: linear-gradient(160deg, #12203d 0%, #1a2f55 50%, #1e3560 100%);
    border-radius: 20px 20px 0 0;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  /* 여권 특유의 기하학적 패턴 배경 */
  .passport-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 18px,
        rgba(201,168,76,0.04) 18px,
        rgba(201,168,76,0.04) 19px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 18px,
        rgba(201,168,76,0.04) 18px,
        rgba(201,168,76,0.04) 19px
      );
    pointer-events: none;
  }

  /* 상단 골드 장식 바 */
  .cover-top-bar {
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
    height: 5px;
    width: 100%;
  }

  /* 하단 골드 장식 바 */
  .cover-bottom-bar {
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
    height: 5px;
    width: 100%;
  }

  .cover-inner {
    padding: 32px 44px 32px;
    position: relative;
    z-index: 1;
  }

  /* 국가명 상단 */
  .cover-country {
    text-align: center;
    margin-bottom: 28px;
  }

  .cover-country-kr {
    font-family: 'Noto Serif KR', serif;
    font-size: 13px;
    letter-spacing: 6px;
    color: rgba(255,255,255,0.75);
    display: block;
    margin-bottom: 2px;
  }

  .cover-country-en {
    font-family: 'DM Serif Display', serif;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold-light);
    opacity: 0.7;
  }

  /* 중앙 문장(紋章) 영역 */
  .cover-crest {
    text-align: center;
    margin-bottom: 24px;
    position: relative;
  }

  /* SVG 원형 문양 */
  .crest-ring {
    width: 96px;
    height: 96px;
    margin: 0 auto 12px;
    position: relative;
  }

  .crest-ring svg {
    width: 100%;
    height: 100%;
  }

  .crest-emoji {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 32px;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
  }

  .cover-title-kr {
    font-family: 'Noto Serif KR', serif;
    font-size: 30px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 8px;
    display: block;
    margin-bottom: 6px;
    text-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .cover-title-en {
    font-family: 'DM Serif Display', serif;
    font-size: 13px;
    letter-spacing: 5px;
    color: var(--gold-light);
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* 골드 구분선 */
  .cover-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 24px 0;
  }

  .cover-divider::before,
  .cover-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201,168,76,0.6));
  }

  .cover-divider::after {
    background: linear-gradient(90deg, rgba(201,168,76,0.6), transparent);
  }

  .cover-divider-diamond {
    width: 6px; height: 6px;
    background: var(--gold);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  /* 개인정보 테이블 - 실제 여권처럼 */
  .cover-info-table {
    width: 100%;
    border-collapse: collapse;
  }

  .cover-info-table tr {
    border-bottom: 1px solid rgba(201,168,76,0.15);
  }

  .cover-info-table tr:last-child {
    border-bottom: none;
  }

  .cover-info-table td {
    padding: 9px 0;
    vertical-align: top;
  }

  .cover-info-table .info-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold-light);
    opacity: 0.65;
    width: 120px;
    padding-right: 16px;
    line-height: 1.8;
  }

  .cover-info-table .info-value {
    font-size: 14px;
    color: var(--white);
    font-weight: 500;
    font-family: 'Noto Sans KR', sans-serif;
    letter-spacing: 0.5px;
  }

  /* MRZ 영역 - 여권 하단 기계판독 줄 */
  .cover-mrz {
    margin-top: 24px;
    padding: 10px 0 0;
    border-top: 1px solid rgba(201,168,76,0.2);
  }

  .mrz-line {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.2);
    line-height: 1.8;
    overflow: hidden;
    white-space: nowrap;
  }

  /* ── 본문 컨테이너 ── */
  .passport-body {
    background: var(--white);
    border-radius: 0 0 20px 20px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  /* ── 섹션 공통 ── */
  .section {
    padding: 28px 36px;
    border-bottom: 1px solid var(--gray-200);
  }

  .section:last-child { border-bottom: none; }

  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .section-flag {
    width: 4px;
    height: 22px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .flag-red { background: var(--red-alert); }
  .flag-yellow { background: var(--yellow-alert); }
  .flag-green { background: var(--green-alert); }
  .flag-navy { background: var(--navy); }

  .section-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .title-red { color: var(--red-alert); }
  .title-yellow { color: var(--yellow-alert); }
  .title-green { color: var(--green-alert); }
  .title-navy { color: var(--navy); }

  /* ── 나는 이런 사람입니다 ── */
  .intro-section {
    background: linear-gradient(135deg, #f8f9ff 0%, #f0f3ff 100%);
    border-left: 4px solid var(--navy-light);
    border-radius: 10px;
    padding: 18px 20px;
    margin-bottom: 20px;
  }

  .intro-section p {
    font-size: 13.5px;
    line-height: 1.9;
    color: var(--gray-600);
  }

  /* ── 기저 의식 수준 ── */
  .consciousness-box {
    background: #fff8f0;
    border: 1px solid #f0c080;
    border-radius: 10px;
    padding: 14px 18px;
    margin-bottom: 20px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .consciousness-box .icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }

  .consciousness-box .label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #b8860b;
    margin-bottom: 4px;
  }

  .consciousness-box p {
    font-size: 13px;
    line-height: 1.7;
    color: var(--gray-700);
  }

  /* ── 진단 태그 ── */
  .diagnosis-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 4px;
  }

  .dx-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    border: 1px solid;
  }

  .dx-tag.primary {
    background: #fff0f0;
    border-color: #f0b4b4;
    color: #c0392b;
  }

  .dx-tag.secondary {
    background: #f0f4ff;
    border-color: #b4c4f0;
    color: #2c4a9e;
  }

  .dx-tag.current {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--gold-light);
    font-weight: 600;
  }

  /* ── 필수 확인 카드 ── */
  .check-grid {
    display: grid;
    gap: 10px;
  }

  .check-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 10px;
    border: 1px solid;
  }

  .check-card.danger {
    background: var(--red-soft);
    border-color: var(--red-border);
  }

  .check-card.warning {
    background: #fff8f0;
    border-color: #f0d090;
  }

  .check-card.info {
    background: #f0f4ff;
    border-color: #c0d0f0;
  }

  .check-card.neutral {
    background: var(--gray-100);
    border-color: var(--gray-200);
  }

  .check-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }

  .check-content .check-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 4px;
  }

  .check-content p {
    font-size: 13px;
    line-height: 1.65;
    color: var(--gray-700);
  }

  .check-content p strong { color: var(--gray-800); }

  /* ── 삽입물 현황 ── */
  .device-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .device-card {
    background: var(--gray-100);
    border: 1px solid var(--gray-200);
    border-radius: 10px;
    padding: 12px 15px;
  }

  .device-name {
    font-size: 11px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }

  .device-detail {
    font-size: 12px;
    color: var(--gray-600);
    line-height: 1.5;
  }

  /* ── 고위험 항목 ── */
  .risk-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
  }

  .risk-card {
    border-radius: 10px;
    padding: 12px 14px;
    text-align: center;
    border: 1px solid;
  }

  .risk-card.high {
    background: #fff0f0;
    border-color: #f0b4b4;
  }

  .risk-card.mid {
    background: #fff8f0;
    border-color: #f0d090;
  }

  .risk-card.low {
    background: #f8f8f8;
    border-color: var(--gray-200);
  }

  .risk-icon { font-size: 22px; display: block; margin-bottom: 6px; }

  .risk-name {
    font-size: 12px;
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 4px;
  }

  .risk-desc {
    font-size: 11px;
    color: var(--gray-400);
    line-height: 1.5;
  }

  /* ── 응급 프로토콜 ── */
  .emergency-box {
    background: linear-gradient(135deg, #1a2744, #2e3f6e);
    border-radius: 12px;
    padding: 20px 22px;
    color: white;
  }

  .emergency-title {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 12px;
    font-weight: 600;
  }

  .protocol-step {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
  }

  .protocol-step:last-child { margin-bottom: 0; }

  .step-num {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--navy);
    font-size: 11px;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .step-text {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,0.9);
  }

  .dnr-alert {
    margin-top: 14px;
    padding: 10px 14px;
    background: rgba(192,57,43,0.25);
    border: 1px solid rgba(192,57,43,0.5);
    border-radius: 8px;
    font-size: 12.5px;
    color: #ffb4ae;
    font-weight: 500;
  }

  /* ── 의사소통 ── */
  .comm-section {
    background: linear-gradient(135deg, #f8f9ff, #eef1ff);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
  }

  .comm-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--navy);
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .comm-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .comm-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--gray-700);
  }

  .comm-list li::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--navy-light);
    flex-shrink: 0;
  }

  .pain-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .pain-badge {
    padding: 6px 14px;
    background: #fff0f0;
    border: 1px solid var(--red-border);
    border-radius: 20px;
    font-size: 12px;
    color: var(--red-alert);
    font-weight: 500;
  }

  /* ── 정보 카드 (알면 도움되는 것) ── */
  .info-block {
    margin-bottom: 20px;
  }

  .info-block:last-child { margin-bottom: 0; }

  .info-block-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--gray-200);
  }

  /* ── 활력징후 테이블 ── */
  .vitals-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    margin-bottom: 10px;
  }

  .vital-cell {
    background: var(--gray-100);
    border-radius: 8px;
    padding: 10px 8px;
    text-align: center;
    border: 1px solid var(--gray-200);
  }

  .vital-cell.last-vs {
    background: #f0f4ff;
    border-color: #c0d0f0;
  }

  .vital-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 5px;
  }

  .vital-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-800);
    line-height: 1.3;
  }

  .vitals-caption {
    font-size: 11px;
    color: var(--gray-400);
    text-align: right;
  }

  /* ── 일반 목록 ── */
  .plain-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .plain-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: var(--gray-600);
    line-height: 1.6;
  }

  .plain-list li::before {
    content: '—';
    color: var(--gray-400);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .plain-list li strong { color: var(--gray-800); }

  /* ── 배변/소변 ── */
  .bowel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .bowel-card {
    background: var(--gray-100);
    border-radius: 10px;
    padding: 14px 16px;
    border: 1px solid var(--gray-200);
  }

  .bowel-card-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 8px;
  }

  .bowel-card p, .bowel-card li {
    font-size: 12.5px;
    color: var(--gray-600);
    line-height: 1.65;
  }

  .bowel-card ul { list-style: none; }
  .bowel-card ul li { padding-left: 12px; position: relative; }
  .bowel-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--gray-400); }

  /* ── 이상징후 ── */
  .alert-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
  }

  .alert-item {
    background: var(--yellow-soft);
    border: 1px solid var(--yellow-border);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 12px;
    color: #7a6000;
    text-align: center;
    font-weight: 500;
  }

  /* ── 감염 타임라인 ── */
  .timeline {
    position: relative;
    padding-left: 20px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 5px; top: 4px; bottom: 4px;
    width: 2px;
    background: var(--gray-200);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 12px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .timeline-item:last-child { margin-bottom: 0; }

  .timeline-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 4px;
    position: absolute;
    left: -17px;
  }

  .dot-danger { background: var(--red-alert); }
  .dot-ok { background: var(--green-alert); }
  .dot-warning { background: var(--yellow-alert); }

  .timeline-date {
    font-size: 11px;
    font-weight: 700;
    color: var(--navy);
    min-width: 60px;
    flex-shrink: 0;
  }

  .timeline-text {
    font-size: 12.5px;
    color: var(--gray-600);
    line-height: 1.5;
  }

  /* ── 검사수치 ── */
  .lab-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
  }

  .lab-table th {
    background: var(--navy);
    color: var(--gold-light);
    font-weight: 600;
    padding: 8px 12px;
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.5px;
  }

  .lab-table th:first-child { border-radius: 8px 0 0 0; text-align: left; }
  .lab-table th:last-child { border-radius: 0 8px 0 0; }

  .lab-table td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--gray-200);
    text-align: center;
    color: var(--gray-600);
  }

  .lab-table td:first-child { text-align: left; font-weight: 500; color: var(--gray-800); }
  .lab-table tr:last-child td { border-bottom: none; }
  .lab-table tr:nth-child(even) td { background: var(--gray-100); }

  .lab-rising { color: var(--red-alert); font-weight: 700; }

  .lab-note {
    margin-top: 8px;
    font-size: 11.5px;
    color: var(--red-alert);
    font-weight: 600;
    text-align: right;
  }

  /* ── 투약 ── */
  .med-section {
    margin-bottom: 16px;
  }

  .med-section:last-child { margin-bottom: 0; }

  .med-category {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--white);
    background: var(--navy-light);
    padding: 4px 12px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 10px;
  }

  .med-category.cat-nutrition { background: #2d6a4f; }
  .med-category.cat-antibiotic { background: var(--red-alert); }
  .med-category.cat-psych { background: #6a3d9a; }
